# ─── Database ────────────────────────────────────────────────────────────────
# Development: SQLite (local file — no setup needed)
DATABASE_URL=file:./dev.db

# Production (uncomment & fill when deploying to Railway/Render/Supabase):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cyberplayground

# ─── Session ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=GENERATE_A_STRONG_SECRET_HERE_MIN_32_CHARS

# ─── Razorpay ────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Create a plan at: https://dashboard.razorpay.com/app/subscriptions/plans
RAZORPAY_PLAN_ID=plan_xxxxxxxxxxxx
# Set in: https://dashboard.razorpay.com/app/webhooks
WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Email (optional — console-logs in dev) ───────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@cyberplayground.io
